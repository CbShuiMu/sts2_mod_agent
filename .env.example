# ─── LLM provider keys ────────────────────────────────────────────────────
# Either set them here, or leave blank and configure via the /api/config UI.
deepseek_api_key=
# OPENAI_API_KEY=        # if you use OpenAI-compatible endpoints

# ─── HuggingFace ──────────────────────────────────────────────────────────
HF_TOKEN=
# HF_ENDPOINT=https://hf-mirror.com   # uncomment if you need a HF mirror

# ─── Embedding model ──────────────────────────────────────────────────────
# Any HuggingFace feature-extraction model id. Default: codefuse-ai/F2LLM-v2-0.6B
EMBEDDING_MODEL=codefuse-ai/F2LLM-v2-0.6B
# Batch size used by PipelineEmbeddings.embed_documents. Default: 16
EMBEDDING_BATCH_SIZE=16

# ─── Milvus ───────────────────────────────────────────────────────────────
# Leave blank to use Milvus Lite (local .db files under data/vector_db/).
# Point to a running server (e.g. via docker-compose.milvus.yml) to switch
# away from Lite.
MILVUS_URI=http://127.0.0.1:19530
# MILVUS_TOKEN=
# MILVUS_DB_NAME=
# DESC_COLLECTION_NAME=sts2_descriptions

# ─── App server ───────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=7870

# ─── RAG defaults ─────────────────────────────────────────────────────────
# CLI flags (--desc-top-k / --code-chars / --default-context-n) still override these.
DESC_TOP_K=4
CONTEXT_N=3
CODE_CHARS=2200

# ─── Tool paths ───────────────────────────────────────────────────────────
# Absolute local paths used by the export / Godot workflows. Configure via
# the Settings page ("工具路径" / "Tool Paths") or edit here directly.
GAME_ROOT=
EXPORT_TOOL_PATH=
GODOT_TOOL_PATH=
